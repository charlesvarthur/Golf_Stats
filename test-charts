import pandas as pd

#Core Data source
golf_stats = pd.read_csv("https://raw.githubusercontent.com/charlesvarthur/Golf_Stats/main/full_stats.csv")

round_comparison = pd.DataFrame(golf_stats.loc[:,['course_name','round_date','score']].groupby(['course_name','round_date'], as_index=False).sum())
round_comparison= round_comparison["score"].rolling(4).mean().dropna()

print(round_comparison)